# Copy this file to supabase/.secrets.env (gitignored, never committed) and
# fill in real values, then run:
#
#   supabase secrets set --env-file supabase/.secrets.env
#
# Do NOT paste real values into a chat/AI conversation — fill this file in
# yourself, locally. SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY
# are NOT listed here because Supabase injects those into every Edge Function
# automatically; setting them manually is unnecessary (and will be rejected).

# Clerk Backend API — Dashboard > API Keys > Secret Key
CLERK_SECRET_KEY=

# Stripe — Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=
# Dashboard > Developers > Webhooks > (the main subscription-lifecycle endpoint) > Signing secret
STRIPE_WEBHOOK_SECRET=
# Dashboard > Developers > Webhooks > (the separate invoice.upcoming-only endpoint) > Signing secret
STRIPE_OVERAGE_WEBHOOK_SECRET=

# Retell — Dashboard > API Keys
RETELL_API_KEY=
# Any long random string you generate yourself — used to verify Retell's
# webhook signature. Must match what you configure in Retell's webhook setup.
RETELL_WEBHOOK_SECRET=

# Twilio — Console > Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Resend — Dashboard > API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Any long random string you generate yourself (e.g. `openssl rand -hex 32`).
# Also needs to be set as the Postgres GUC app.settings.workflow_trigger_secret
# (see the printed `alter database` commands after you fill this in) — the
# two values must match exactly.
WORKFLOW_TRIGGER_SECRET=
