# Set these with `supabase secrets set --env-file supabase/functions/.env`
# (after filling in real values — never commit real secrets).
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are provided
# automatically by the platform and don't need to be set here.

# Retell dashboard > API Keys
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Any random string. Append `?secret=<this value>` to the inbound_webhook_url
# you configure on each Retell phone number, so retell-inbound-webhook can
# verify the request actually came from your Retell setup and not a random
# caller of the public function URL.
RETELL_WEBHOOK_SECRET=replace-with-a-long-random-string

# Twilio Console > Account Info. TWILIO_PHONE_NUMBER is the single Twilio
# number every AI Employee sends SMS from (E.164 format, e.g. +15551234567).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# Resend dashboard > API Keys. RESEND_FROM_EMAIL must be an address on a
# domain you've verified in Resend, e.g. "AI Employee <noreply@yourdomain.com>" —
# sends will fail (RESEND_API_ERROR) against an unverified domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=AI Employee <noreply@yourdomain.com>

# Any random string. Must match app.settings.workflow_trigger_secret, set at
# the database level (see the header comment in migration 0011) — Postgres
# sends this in an X-Workflow-Trigger-Secret header when it invokes
# workflow-executor / resume-scheduled-workflows / process-campaign-batch,
# since the caller there is our own trigger function or pg_cron, not Retell
# or a browser.
WORKFLOW_TRIGGER_SECRET=replace-with-a-long-random-string

# Stripe Dashboard > Developers > API keys. Also used by scripts/setup-stripe.mjs
# (run from your own machine, not set as a Supabase secret for that use).
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Printed by scripts/setup-stripe.mjs when it creates your webhook endpoint
# (or Stripe Dashboard > Developers > Webhooks > your endpoint > Signing
# secret, if you created it by hand / need to look it up again).
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The signing secret for the SECOND Stripe webhook endpoint (calculate-overage,
# subscribed to invoice.upcoming only) — printed by the same setup-stripe.mjs
# run, distinct from STRIPE_WEBHOOK_SECRET above since it's a different
# endpoint with its own secret.
STRIPE_OVERAGE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk Dashboard > API Keys > Secret Key. Server-side only — distinct from
# the frontend's VITE_CLERK_PUBLISHABLE_KEY (.env.example at the repo root).
# Used by partner-register / create-client-organization to call Clerk's
# Backend API directly (create organizations, add memberships).
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NOT a Supabase secret — this is a database-level setting (a Postgres GUC),
# same mechanism as app.settings.workflow_trigger_secret (migration 0011).
# Comma-separated list of Clerk user ids (the "user_..." id, not an email)
# who get JHDMAdminPage access. Set it with:
#   alter database postgres set "app.settings.jhdm_admin_clerk_user_ids" = 'user_xxx,user_yyy';
# Left here only as a reminder of where to find it — there's nothing to put
# in a Supabase secrets file for this one.
